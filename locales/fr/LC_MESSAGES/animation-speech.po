#: animation_speech/main.py:146
msgid "Speech animation for Wayland controlled by UNIX signals"
msgstr "Animation de parole pour Wayland contrôlée par signaux UNIX"

#: animation_speech/main.py:148
#, python-format
msgid ""
"\n"
"Usage examples:\n"
"  %(prog)s --list                             # List all available configs\n"
"  %(prog)s                                    # Default configuration\n"
"  %(prog)s monochrome-bw                      # Just the name (adds .yaml "
"auto)\n"
"  %(prog)s wave-energetic                     # Another example\n"
"  %(prog)s -w 1200 -mb 50                     # Width 1200px, 50px from "
"bottom\n"
"  %(prog)s monochrome-bw -w 1400 -H 150       # Config + dimension "
"overrides\n"
"\n"
"Control:\n"
"  kill -SIGUSR1 <PID>    # Start animation\n"
"  kill -SIGUSR2 <PID>    # Stop animation\n"
"\n"
"Automatic search:\n"
"  For \"monochrome-bw\" -> searches \"monochrome-bw.yaml\" in:\n"
"  1. ~/.config/animation-speech/\n"
"  2. ~/.local/share/animation-speech/config.examples/\n"
"  3. /usr/local/share/animation-speech/config.examples/\n"
"  4. Script directory/config.examples/\n"
"        "
msgstr ""
"\n"
"Exemples d'utilisation :\n"
"  %(prog)s --list                             # Lister toutes les configs "
"disponibles\n"
"  %(prog)s                                    # Configuration par défaut\n"
"  %(prog)s monochrome-bw                      # Juste le nom (ajoute .yaml "
"auto)\n"
"  %(prog)s wave-energetic                     # Autre exemple\n"
"  %(prog)s -w 1200 -mb 50                     # Largeur 1200px, 50px du "
"bas\n"
"  %(prog)s monochrome-bw -w 1400 -H 150       # Config + surcharge "
"dimensions\n"
"\n"
"Contrôle :\n"
"  kill -SIGUSR1 <PID>    # Démarrer l'animation\n"
"  kill -SIGUSR2 <PID>    # Arrêter l'animation\n"
"\n"
"Recherche automatique :\n"
"  Pour \"monochrome-bw\" → cherche \"monochrome-bw.yaml\" dans :\n"
"  1. ~/.config/animation-speech/\n"
"  2. ~/.local/share/animation-speech/config.examples/\n"
"  3. /usr/local/share/animation-speech/config.examples/\n"
"  4. Répertoire du script/config.examples/\n"
"        "

